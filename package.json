{
  "name": "pomo",
  "version": "1.0.0",
  "description": "Pomo — a simple, refined Pomodoro focus & to-do PWA",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview --host",
    "cap:sync": "cap sync android",
    "android:sync": "npm run build && cap sync android",
    "android:apk": "npm run build && cap sync android && cd android && ./gradlew assembleDebug",
    "android:apk:release": "npm run build && cap sync android && cd android && ./gradlew assembleRelease",
    "android:aab": "npm run build && cap sync android && cd android && ./gradlew bundleRelease",
    "android:open": "cap open android",
    "keystore": "bash scripts/gen-keystore.sh",
    "android:icons": "node scripts/gen-icons.mjs && node scripts/gen-android-icons.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/33modeling/pomo.git"
  },
  "keywords": [
    "pomodoro",
    "pwa",
    "productivity",
    "focus",
    "todo",
    "timer"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/33modeling/pomo/issues"
  },
  "homepage": "https://github.com/33modeling/pomo#readme",
  "devDependencies": {
    "@capacitor/cli": "^7.6.7",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.7",
    "@capacitor/core": "^7.6.7",
    "@capacitor/local-notifications": "^7.0.6",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dexie": "^4.4.4",
    "dexie-react-hooks": "^4.4.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "zustand": "^5.0.14"
  }
}
